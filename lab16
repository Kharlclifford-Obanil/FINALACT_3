<?php

if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $age = $_POST["age"] ?? "";

    if ($age == "") {
        echo "Please enter your age.";
    } elseif ($age < 1 || $age > 100) {
        echo "Invalid age range.";
    } else {
        echo "Valid age: " . $age;
    }
}


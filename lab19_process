<h2>Submitted Data</h2>

<?php

if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $name = htmlspecialchars($_POST["name"] ?? "");
    $email = htmlspecialchars($_POST["email"] ?? "");

    if (empty($name) || empty($email)) {
        echo "Please fill in all fields.";
    } else {
        echo "Name: " . $name . "<br>";
        echo "Email: " . $email;
    }

} else {
    echo "No data received.";
}


<?php
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    $message = $_POST["message"];

    if (empty($message)) {
        echo "Please enter a message.";
    } else {
        echo "<h3>Your Message:</h3>";
        echo "<p>" . htmlspecialchars($message) . "</p>";
    }
}
?>


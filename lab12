<!DOCTYPE html>
<html>
<body>

<form method="POST">

    <label>Name:</label><br>
    <input type="text" name="name"
        value="<?php echo htmlspecialchars($_POST['name'] ?? ''); ?>"><br><br>

    <label>Email:</label><br>
    <input type="text" name="email"
        value="<?php echo htmlspecialchars($_POST['email'] ?? ''); ?>"><br><br>

